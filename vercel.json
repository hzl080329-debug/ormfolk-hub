{
  "functions": {
    "src/app/api/**/*": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/kimbap/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/uploads/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
